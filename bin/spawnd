#!/usr/bin/env python3
"""spawnd: long-running spawn daemon entrypoint."""

from __future__ import annotations

import argparse
import json
import os
import shlex
import subprocess
import sys
import time
import uuid
from pathlib import Path
from typing import Any


def append_log(path: Path, row: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(row, sort_keys=True) + "\n")


def iter_jsonl_from_command(command: str):
    proc = subprocess.Popen(
        shlex.split(command),
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    assert proc.stdout is not None
    try:
        for line in proc.stdout:
            line = line.strip()
            if line:
                yield line
    finally:
        proc.terminate()


def run_refresh(command: str) -> tuple[int, str, str]:
    cp = subprocess.run(
        shlex.split(command),
        capture_output=True,
        text=True,
        check=False,
    )
    return cp.returncode, cp.stdout.strip(), cp.stderr.strip()


def cmd_codex_refresh(args: argparse.Namespace) -> int:
    topics = {topic.strip() for topic in args.topics.split(",") if topic.strip()}
    log_path = Path(args.log_path).expanduser()
    last_run = 0.0

    for line in iter_jsonl_from_command(args.source_command):
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            append_log(
                log_path,
                {
                    "event_id": str(uuid.uuid4()),
                    "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
                    "action": "codex_refresh",
                    "return_code": 1,
                    "stdout": "",
                    "stderr": "invalid event jsonl line",
                    "event": {"raw": line},
                },
            )
            continue

        topic = event.get("topic")
        if not isinstance(topic, str) or topic not in topics:
            continue

        now = time.monotonic()
        if (now - last_run) < args.debounce_seconds:
            continue
        last_run = now

        rc, out, err = run_refresh(args.refresh_command)
        append_log(
            log_path,
            {
                "event_id": str(uuid.uuid4()),
                "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
                "action": "codex_refresh",
                "return_code": rc,
                "stdout": out,
                "stderr": err,
                "event": event,
            },
        )

    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    sub = parser.add_subparsers(dest="cmd", required=True)

    p = sub.add_parser(
        "codex-session-refresh",
        help="Run codex-refresh-context on selected codex event topics",
    )
    p.add_argument(
        "--source-command",
        default="python /home/_404/src/spawn/bin/codex-event-source",
    )
    p.add_argument(
        "--refresh-command",
        default="codex-refresh-context --wait-session-write",
    )
    p.add_argument(
        "--topics",
        default="codex.session.started,codex.session.ended",
        help="Comma-separated topics that trigger refresh",
    )
    p.add_argument("--debounce-seconds", type=float, default=2.0)
    p.add_argument(
        "--log-path",
        default="~/.local/state/codex/spawn/spawnd-codex-session-refresh.jsonl",
    )
    p.set_defaults(func=cmd_codex_refresh)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
