{
  "components": [
    {
      "entrypoint": "spawn.core.service:main",
      "name": "spawnd",
      "role": "daemon"
    },
    {
      "entrypoint": "spawn.cli.app:main",
      "name": "spawnctl",
      "role": "cli"
    },
    {
      "entrypoint": "src/spawn/contracts/models.py",
      "name": "contracts",
      "role": "schema"
    }
  ],
  "contracts": [
    {
      "kind": "proto",
      "lifecycle": "canonical",
      "name": "spawn_control",
      "path": "api/proto/spawn/v1/spawn_control.proto"
    },
    {
      "kind": "openapi",
      "lifecycle": "derived",
      "name": "openapi_component_catalog",
      "path": "api/openapi/openapi.yaml"
    },
    {
      "kind": "pydantic_model",
      "lifecycle": "canonical",
      "name": "runtime_contract_models",
      "path": "src/spawn/contracts/models.py"
    },
    {
      "kind": "json_schema",
      "lifecycle": "derived",
      "name": "tool_ssot",
      "path": "api/openapi/schemas/ToolSsotV1.schema.json"
    }
  ],
  "dependencies": [
    {
      "kind": "runtime",
      "name": "grpcio",
      "note": "",
      "required": true
    },
    {
      "kind": "runtime",
      "name": "pydantic",
      "note": "",
      "required": true
    },
    {
      "kind": "runtime",
      "name": "dataconfy",
      "note": "",
      "required": true
    },
    {
      "kind": "runtime",
      "name": "xdg-base-dirs",
      "note": "",
      "required": true
    },
    {
      "kind": "runtime",
      "name": "protobuf",
      "note": "",
      "required": true
    },
    {
      "kind": "build",
      "name": "grpcio-tools",
      "note": "Used only by scripts/gen.sh via uv --with",
      "required": false
    }
  ],
  "schema": "tool_ssot_v1",
  "tool": "spawn",
  "version": "0.1.0"
}
