{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence.bundle.telemetry.schema.json",
  "title": "evidence.bundle.telemetry",
  "type": "object",
  "required": [
    "otel",
    "signals"
  ],
  "properties": {
    "otel": {
      "type": "object",
      "required": [
        "trace_id_hex",
        "span_id_hex"
      ],
      "properties": {
        "backend": {
          "type": "string"
        },
        "trace_id_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]{32}$"
        },
        "span_id_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$"
        },
        "run_id": {
          "type": "string"
        }
      },
      "additionalProperties": true,
      "description": "OpenTelemetry correlation identifiers and optional backend metadata."
    },
    "signals": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "./evidence.capsule.schema.json#/definitions/artifact"
      }
    }
  },
  "additionalProperties": true,
  "description": "Telemetry bundle linking traces, scalar signals, and optional artifact references."
}
