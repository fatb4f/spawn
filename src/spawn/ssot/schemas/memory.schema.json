{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "memory.schema.json",
  "title": "memory",
  "description": "Canonical memory state snapshot derived from the append-only memory event stream.",
  "$comment": "SSOT payload for rebuild outputs. Persisted under state directory and validated before write.",
  "type": "object",
  "required": [
    "schema_name",
    "schema_version",
    "memory",
    "proposals",
    "tombstones"
  ],
  "properties": {
    "schema_name": {
      "const": "memory",
      "description": "Schema discriminator for memory state documents."
    },
    "schema_version": {
      "const": "v1",
      "description": "Schema version for backward-compatible parsing."
    },
    "memory": {
      "type": "array",
      "description": "Materialized memory items, including accepted and deprecated entries.",
      "items": {
        "$ref": "#/definitions/memory_item"
      }
    },
    "proposals": {
      "type": "array",
      "description": "Memory proposals pending or already reviewed by operator policy.",
      "items": {
        "$ref": "#/definitions/memory_proposal"
      }
    },
    "tombstones": {
      "type": "array",
      "description": "Deprecation records emitted when accepted memory is retired.",
      "items": {
        "$ref": "#/definitions/memory_tombstone"
      }
    }
  },
  "definitions": {
    "memory_item": {
      "type": "object",
      "description": "Accepted memory entity used for downstream context rendering and decision support.",
      "required": [
        "memory_id",
        "id",
        "kind",
        "claim",
        "value",
        "provenance",
        "first_seen_at",
        "last_seen_at",
        "status"
      ],
      "properties": {
        "memory_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable identifier derived from kind+value."
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Compatibility alias of memory_id."
        },
        "kind": {
          "description": "Semantic class of memory used by extraction and gating policy.",
          "enum": [
            "preference",
            "identity",
            "project_fact",
            "workflow",
            "constraint",
            "glossary"
          ]
        },
        "claim": {
          "type": "string",
          "minLength": 1,
          "description": "Natural-language claim suitable for rendering in prompt context."
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "description": "Normalized value used for idempotency and duplicate detection."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Extractor confidence score in range [0,1]."
        },
        "provenance": {
          "type": "object",
          "additionalProperties": true,
          "description": "Evidence/source metadata (for example source_ref, excerpts, trace references)."
        },
        "first_seen_at": {
          "type": "string",
          "format": "date-time",
          "description": "First observation timestamp in UTC."
        },
        "last_seen_at": {
          "type": "string",
          "format": "date-time",
          "description": "Most recent observation timestamp in UTC."
        },
        "status": {
          "description": "Lifecycle state of the memory item.",
          "enum": [
            "accepted",
            "deprecated"
          ]
        },
        "tags": {
          "type": "array",
          "description": "Optional operator or pipeline tags for filtering and grouping.",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "memory_proposal": {
      "type": "object",
      "description": "Candidate memory requiring review when auto-accept policy does not apply.",
      "required": [
        "proposal_id",
        "kind",
        "claim",
        "value",
        "confidence",
        "source",
        "evidence",
        "proposed_by",
        "gate_reason",
        "status",
        "created_at"
      ],
      "properties": {
        "proposal_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable identifier for the proposal record."
        },
        "memory_id": {
          "type": "string",
          "description": "Target memory_id to be created/updated if proposal is accepted."
        },
        "kind": {
          "description": "Proposed memory class.",
          "enum": [
            "preference",
            "identity",
            "project_fact",
            "workflow",
            "constraint",
            "glossary"
          ]
        },
        "claim": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable candidate claim."
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "description": "Normalized candidate value."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Extractor confidence score in range [0,1]."
        },
        "source": {
          "type": "object",
          "additionalProperties": true,
          "description": "Source metadata for operator review (path, line, trace, session refs)."
        },
        "evidence": {
          "type": "array",
          "description": "Supporting snippets that justify the proposal.",
          "items": {
            "type": "string"
          }
        },
        "proposed_by": {
          "type": "string",
          "description": "Extractor identity/version that produced this proposal."
        },
        "gate_reason": {
          "type": "string",
          "description": "Reason the proposal was not auto-accepted."
        },
        "status": {
          "description": "Review workflow status.",
          "enum": [
            "pending",
            "accepted",
            "rejected"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Proposal creation timestamp in UTC."
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when proposal was accepted/rejected."
        }
      },
      "additionalProperties": true
    },
    "memory_tombstone": {
      "type": "object",
      "description": "Deprecation marker for memory removed from active context.",
      "required": [
        "memory_id",
        "reason",
        "at"
      ],
      "properties": {
        "memory_id": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier of deprecated memory item."
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Reason code or textual explanation for deprecation."
        },
        "at": {
          "type": "string",
          "format": "date-time",
          "description": "Deprecation timestamp in UTC."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
