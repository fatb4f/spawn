{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gate.decision.schema.json",
  "title": "gate.decision",
  "type": "object",
  "required": [
    "schema_name",
    "schema_version",
    "run_id",
    "task_id",
    "status",
    "reason_codes",
    "telemetry_ref"
  ],
  "properties": {
    "schema_name": {
      "const": "gate.decision"
    },
    "schema_version": {
      "const": "v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "APPROVE",
        "REJECT",
        "NEEDS_HUMAN"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]+(\\.[A-Z0-9_]+)+$"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "telemetry_ref": {
      "$ref": "./evidence.bundle.telemetry.schema.json"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
