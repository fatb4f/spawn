{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.contract.schema.json",
  "title": "schema.contract",
  "type": "object",
  "required": [
    "schema_name",
    "schema_version",
    "contract_id",
    "subject",
    "authoritative_source",
    "validation_rule"
  ],
  "properties": {
    "schema_name": {
      "const": "schema.contract"
    },
    "schema_version": {
      "const": "v1"
    },
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "required_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "validation_rule": {
      "type": "string",
      "minLength": 1
    },
    "authoritative_source": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    }
  },
  "additionalProperties": false,
  "description": "Canonical contract metadata for SSOT-governed schemas and validation rules."
}
