{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run.manifest.schema.json",
  "title": "run.manifest",
  "type": "object",
  "required": [
    "schema_name",
    "schema_version",
    "run_id",
    "inputs",
    "commands",
    "artifacts",
    "runtime"
  ],
  "properties": {
    "schema_name": {
      "const": "run.manifest"
    },
    "schema_version": {
      "const": "v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true
    },
    "refs": {
      "type": "object",
      "additionalProperties": true
    },
    "budgets": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Reproducibility manifest for one run, including inputs, commands, artifacts, and runtime metadata."
}
