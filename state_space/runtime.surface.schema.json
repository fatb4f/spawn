{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://_404.local/discussions/state_space/runtime.surface.schema.json",
  "title": "runtime.surface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "surface_id",
    "owner",
    "managed_kind",
    "binary",
    "entrypoints",
    "launch_surfaces",
    "xdg_dirs",
    "owned_paths",
    "writable_paths",
    "env_contract",
    "systemd_units",
    "credentials",
    "ipc",
    "ports_or_sockets",
    "verification_rules",
    "render_targets"
  ],
  "properties": {
    "schema_name": {
      "const": "runtime.surface"
    },
    "schema_version": {
      "const": "v1"
    },
    "surface_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "managed_kind": {
      "type": "string",
      "enum": [
        "application",
        "binary",
        "service",
        "wrapper"
      ]
    },
    "binary": {
      "type": "string",
      "minLength": 1
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_target"
      }
    },
    "launch_surfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_target"
      }
    },
    "xdg_dirs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config",
        "state",
        "cache",
        "data",
        "runtime"
      ],
      "properties": {
        "config": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": [
            "string",
            "null"
          ]
        },
        "cache": {
          "type": [
            "string",
            "null"
          ]
        },
        "data": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtime": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "owned_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "writable_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "env_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "set",
        "optional"
      ],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "set": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "systemd_units": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/systemd_unit"
      }
    },
    "credentials": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_target"
      }
    },
    "ipc": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_target"
      }
    },
    "ports_or_sockets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_target"
      }
    },
    "verification_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verification_rule"
      }
    },
    "render_targets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_target"
      }
    },
    "config_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_target"
      },
      "default": []
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "named_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "systemd_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "name",
        "role"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "user",
            "system"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "primary",
            "supporting",
            "trigger"
          ]
        }
      }
    },
    "verification_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "command",
        "expected"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "schema",
            "shell-syntax",
            "systemd-verify",
            "binary-available",
            "manual"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "expected": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
