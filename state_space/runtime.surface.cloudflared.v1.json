{
  "schema_name": "runtime.surface",
  "schema_version": "v1",
  "surface_id": "cloudflared",
  "owner": "dotfiles",
  "managed_kind": "service",
  "binary": "/usr/bin/cloudflared",
  "entrypoints": [
    {
      "kind": "systemd_unit",
      "value": "dotfiles/system/cloudflared.service"
    }
  ],
  "launch_surfaces": [
    {
      "kind": "systemd_system",
      "value": "cloudflared.service"
    }
  ],
  "xdg_dirs": {
    "config": "/home/_404/.config/cloudflared",
    "state": "/home/_404/.local/state",
    "cache": null,
    "data": "/home/_404/.local/share",
    "runtime": null
  },
  "owned_paths": [
    "/home/_404/.config/cloudflared/config.yml",
    "/etc/credstore.encrypted/cloudflared-tunnel.cred"
  ],
  "writable_paths": [
    "/home/_404/.local/state"
  ],
  "env_contract": {
    "required": [
      "XDG_CONFIG_HOME",
      "XDG_STATE_HOME",
      "XDG_DATA_HOME",
      "XDG_CONFIG_DIRS",
      "XDG_DATA_DIRS"
    ],
    "set": {
      "XDG_CONFIG_HOME": "/home/_404/.config",
      "XDG_DATA_HOME": "/home/_404/.local/share",
      "XDG_STATE_HOME": "/home/_404/.local/state"
    },
    "optional": []
  },
  "systemd_units": [
    {
      "scope": "system",
      "name": "cloudflared.service",
      "role": "primary"
    }
  ],
  "credentials": [
    {
      "kind": "systemd_credential_encrypted",
      "value": "/etc/credstore.encrypted/cloudflared-tunnel.cred"
    }
  ],
  "ipc": [],
  "ports_or_sockets": [
    {
      "kind": "egress",
      "value": "cloudflare edge over outbound tunnel connection"
    }
  ],
  "verification_rules": [
    {
      "kind": "systemd-verify",
      "command": "systemctl cat cloudflared.service",
      "expected": "unit resolves LoadCredentialEncrypted and XDG env"
    },
    {
      "kind": "binary-available",
      "command": "command -v /usr/bin/cloudflared",
      "expected": "exit 0"
    },
    {
      "kind": "manual",
      "command": "cloudflared tunnel --config /home/_404/.config/cloudflared/config.yml ingress validate",
      "expected": "config validates"
    }
  ],
  "render_targets": [
    {
      "kind": "unit",
      "value": "dotfiles/system/cloudflared.service"
    },
    {
      "kind": "config",
      "value": "dotfiles/config/cloudflared/config.yml"
    }
  ],
  "config_artifacts": [
    {
      "kind": "config",
      "value": "dotfiles/config/cloudflared/config.yml"
    }
  ],
  "notes": [
    "Cloudflared is a system-level managed service with encrypted credential loading.",
    "Its runtime surface is authoritative even though only one unit and one config file are rendered."
  ]
}
