{
  "schema_name": "runtime.surface",
  "schema_version": "v1",
  "surface_id": "codex",
  "owner": "dotfiles",
  "managed_kind": "application",
  "binary": "/usr/bin/codex",
  "entrypoints": [
    {
      "kind": "fish_function",
      "value": "dotfiles/config/fish/functions/codex.fish"
    },
    {
      "kind": "wrapper",
      "value": "dotfiles/local/bin/codex-vscode"
    }
  ],
  "launch_surfaces": [
    {
      "kind": "shell",
      "value": "codex"
    },
    {
      "kind": "desktop_entry",
      "value": "dotfiles/local/share/applications/codex.desktop"
    },
    {
      "kind": "desktop_entry",
      "value": "dotfiles/local/share/applications/codex-launcher.desktop"
    },
    {
      "kind": "vscode_extension",
      "value": "chatgpt.cliExecutable=/home/_404/.local/bin/codex-vscode"
    }
  ],
  "xdg_dirs": {
    "config": "/home/_404/.config/codex",
    "state": "/home/_404/.local/state/codex",
    "cache": "/home/_404/.cache/codex",
    "data": null,
    "runtime": null
  },
  "owned_paths": [
    "/home/_404/.config/codex/config.toml",
    "/home/_404/.config/codex/otel.env",
    "/home/_404/.local/state/codex/meta/effective_prompt.txt",
    "/home/_404/.local/state/codex/meta/generated_prompt_context.txt"
  ],
  "writable_paths": [
    "/home/_404/.local/state/codex",
    "/home/_404/.cache/codex"
  ],
  "env_contract": {
    "required": [
      "XDG_CONFIG_HOME",
      "XDG_STATE_HOME",
      "XDG_CACHE_HOME",
      "CODEX_HOME",
      "CODEX_STATE"
    ],
    "set": {
      "CODEX_HOME": "/home/_404/.config/codex",
      "CODEX_STATE": "/home/_404/.local/state/codex"
    },
    "optional": [
      "PRJROOT",
      "OTEL_EXPORTER_OTLP_ENDPOINT"
    ]
  },
  "systemd_units": [
    {
      "scope": "user",
      "name": "codex-acp.service",
      "role": "supporting"
    },
    {
      "scope": "user",
      "name": "spawnd-codex-session-refresh.path",
      "role": "trigger"
    },
    {
      "scope": "user",
      "name": "spawnd-codex-session-refresh.service",
      "role": "supporting"
    }
  ],
  "credentials": [],
  "ipc": [
    {
      "kind": "tcp",
      "value": "127.0.0.1:3021"
    }
  ],
  "ports_or_sockets": [
    {
      "kind": "tcp",
      "value": "127.0.0.1:3021"
    }
  ],
  "verification_rules": [
    {
      "kind": "shell-syntax",
      "command": "fish -n dotfiles/config/fish/functions/codex.fish && bash -n dotfiles/local/bin/codex-vscode",
      "expected": "exit 0"
    },
    {
      "kind": "systemd-verify",
      "command": "systemctl --user cat codex-acp.service",
      "expected": "unit resolves with expected XDG env and CacheDirectory"
    },
    {
      "kind": "binary-available",
      "command": "command -v /usr/bin/codex",
      "expected": "exit 0"
    }
  ],
  "render_targets": [
    {
      "kind": "wrapper",
      "value": "dotfiles/config/fish/functions/codex.fish"
    },
    {
      "kind": "wrapper",
      "value": "dotfiles/local/bin/codex-vscode"
    },
    {
      "kind": "unit",
      "value": "dotfiles/units/user/codex-acp.service"
    }
  ],
  "config_artifacts": [
    {
      "kind": "config",
      "value": "dotfiles/config/codex/config.toml"
    },
    {
      "kind": "env_file",
      "value": "dotfiles/config/codex/otel.env"
    }
  ],
  "notes": [
    "Codex is managed across shell, desktop, VS Code, and ACP service surfaces.",
    "Interactive wrappers bridge cache directory creation outside direct systemd ownership."
  ]
}
